{
  "name": "pagebloomfilter",
  "version": "1.3.0",
  "description": "Page Bloom Filter for JavaScript and WebAssembly runtimes",
  "author": "Ruan Kunliang",
  "keywords": [
    "bloom-filter",
    "probabilistic-data-structure",
    "webassembly"
  ],
  "homepage": "https://github.com/PeterRK/PageBloomFilter#readme",
  "bugs": {
    "url": "https://github.com/PeterRK/PageBloomFilter/issues"
  },
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterRK/PageBloomFilter.git",
    "directory": "typescript"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build:wasm": "node scripts/build-wasm.mjs",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run clean && npm run build:wasm && npm run build:ts",
    "prepack": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs",
    "benchmark": "npm run benchmark:binary",
    "benchmark:binary": "npm run build && node --expose-gc benchmark/benchmark.mjs --mode=binary",
    "benchmark:string": "npm run build && node --expose-gc benchmark/benchmark.mjs --mode=string"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bloomfilter": "^1.1.0",
    "fast-bloom-filter": "^3.0.0",
    "mnemonist": "^0.40.4",
    "typescript": "^7.0.2"
  }
}
